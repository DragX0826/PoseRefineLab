# MaxFlow - GitHub Ignore Pattern
# ---
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class
*.so

# Environments
.env
.venv
env/
venv/
ENV/

# Model Weights
*.pt
*.pth
*.ckpt
!maxflow-core/checkpoints/maxflow_pretrained.pt
!maxflow_pretrained.pt

# Weights & Large Checkpoints
maxflow-core/checkpoints/

# Data & Results
maxflow_results.zip
maxflow-core/data/*.pdb
maxflow-core/data/*.csv
!maxflow-core/data/baselines_results.csv # Keep baselines for demo
!maxflow-core/data/test_set_split.csv

# Output
fig*.pdf
fig*.png
results_table.tex
generated_candidates.sdf
archive/
cache/
results/
Final_Submission_Data/
quantum/qm_negative_result_package/
quantum/outputs/
*.log
*.zip
results/
deliverables/*.zip

!deliverables/
!deliverables/workshop_evidence/
!deliverables/workshop_evidence/**

# VS Code / IDE
.vscode/
.idea/
.DS_Store
